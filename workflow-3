        "jsCode": "const allItems = $input.all();\n\nif (!allItems || allItems.length === 0) {\n  throw new Error('No data received. Please check your node connections.');\n}\n\nconst data = allItems[0].json;\n\n// Form fields coming from Form Trigger via Merge\nconst newStage = data['New Stage'] ?? data['new_stage'] ?? '';\nconst counsellorName = data['Counsellor Name'] ?? data['counsellor_name'] ?? '';\nconst notes = data['Notes'] ?? data['notes'] ?? '';\nconst submittedStudentId = data['Student ID'] ?? data['student_id'] ?? '';\n\n// Sheet fields coming from Find Student Record via Merge\nconst studentId = data['Student_ID'] ?? submittedStudentId;\nconst fullName = data['Full Name'] ?? '';\n\n// Validate student was found\nif (!studentId && !fullName) {\n  throw new Error(\n    `Student ID \"${submittedStudentId}\" was not found in the Student Pipeline. Please check the ID and try again.`\n  );\n}\n\n// Validate new stage was provided\nif (!newStage) {\n  throw new Error('New Stage is missing. Please ensure the form was filled correctly.');\n}\n\nconst stageMap = {\n  'New Inquiry': 1,\n  'Qualified Lead': 2,\n  'Counselling Completed': 3,\n  'Application Started': 4,\n  'Documents Submitted': 5,\n  'University Submission': 6,\n  'Offer Letter Received': 7,\n  'Acceptance & Deposit Paid': 8,\n  'CAS/I-20/CoE Issued': 9,\n  'Pre-Visa Documentation': 10,\n  'Visa Processing': 11,\n  'Visa Approved': 12,\n  'Pre-Departure Briefing': 13,\n  'Enrolled/Arrived': 14,\n  'Visa Refused': 15,\n  'Reapplication in Progress': 16,\n  'Deferred': 17,\n  'Withdrawn': 18\n};\n\nconst stageNumber = stageMap[newStage] ?? 1;\n\nconst now = new Date().toLocaleString('en-GB', {\n  timeZone: 'Africa/Lagos',\n  day: '2-digit',\n  month: 'long',\n  year: 'numeric',\n  hour: '2-digit',\n  minute: '2-digit',\n  second: '2-digit',\n  hour12: false\n});\n\nreturn [\n  {\n    json: {\n      student_id: studentId,\n      full_name: fullName,\n      whatsapp_number: data['WhatsApp Number'] ?? '',\n      student_email: data['Email'] ?? data['Email Address'] ?? '',\n      preferred_destination: data['Preferred Destination'] ?? '',\n      intended_course: data['Intended Course'] ?? '',\n      target_intake: data['Target Intake'] ?? '',\n      assigned_counsellor: data['Assigned Counsellor'] ?? '',\n      counsellor_email: data['Counsellor Email'] ?? '',\n      folder_link: data['Drive Folder Link'] ?? '',\n      previous_stage: data['Current Stage'] ?? '',\n      new_stage: newStage,\n      stage_number: stageNumber,\n      stage_updated_at: now,\n      counsellor_name: counsellorName,\n      notes: notes\n    }\n  }\n];"
