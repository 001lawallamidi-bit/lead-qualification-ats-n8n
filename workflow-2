        "message": "=<!DOCTYPE html>\n<html>\n<head>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    body { font-family: 'Inter'; background-color: #f4f6f9; margin: 0; padding: 24px; color: #111827; }\n    .container { max-width: 700px; margin: 0 auto; background: #ffffff; border-radius: 16px; overflow: hidden; box-shadow: 0 8px 24px rgba(0,0,0,0.08); }\n    .header { background: linear-gradient(135deg, #1a3c6e, #274f8a); padding: 32px; text-align: center; }\n    .header h1 { margin: 0; color: #ffffff; font-size: 26px; font-weight: 700; }\n    .header p { margin: 10px 0 0; color: #d7e4f7; font-size: 14px; }\n    .stage-banner { background: #f59e0b; color: #ffffff; text-align: center; padding: 14px; font-size: 15px; font-weight: 600; }\n    .section { padding: 28px 30px; border-bottom: 1px solid #eef2f7; }\n    .section:last-child { border-bottom: none; }\n    .section-title { margin: 0 0 18px; color: #1a3c6e; font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; }\n    .id-card { background: #f0f4ff; border: 1px solid #d8e3ff; border-radius: 12px; padding: 20px; text-align: center; }\n    .student-id { font-size: 30px; font-weight: 700; color: #1a3c6e; letter-spacing: 3px; }\n    .id-note { margin-top: 10px; font-size: 12px; color: #6b7280; }\n    .info-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }\n    .info-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; padding: 14px; }\n    .info-label { font-size: 11px; text-transform: uppercase; letter-spacing: .6px; color: #6b7280; margin-bottom: 6px; font-weight: 600; }\n    .info-value { font-size: 14px; color: #111827; font-weight: 500; line-height: 1.5; word-break: break-word; }\n    .status-pill { display: inline-block; background: #e8f4ff; color: #1a3c6e; padding: 6px 12px; border-radius: 999px; font-size: 13px; font-weight: 600; }\n    .score-card {