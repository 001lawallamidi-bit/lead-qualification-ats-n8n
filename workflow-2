lue\">{{ $json['Preferred Destination'] }}</div>\n      </div>\n\n      <div class=\"info-card\">\n        <div class=\"info-label\">Intended Course</div>\n        <div class=\"info-value\">{{ $json['Intended Course'] }}</div>\n      </div>\n\n      <div class=\"info-card\">\n        <div class=\"info-label\">Target Intake</div>\n        <div class=\"info-value\">{{ $json['Target Intake'] }}</div>\n      </div>\n\n      <div class=\"info-card\">\n        <div class=\"info-label\">Budget</div>\n        <div class=\"info-value\">{{ $json.Budget }}</div>\n      </div>\n\n      <div class=\"info-card\">\n        <div class=\"info-label\">AI Status</div>\n        <div class=\"info-value\"><span class=\"status-pill\">{{ $json['AI Status'] }}</span></div>\n      </div>\n\n      <div class=\"info-card score-card\">\n        <div class=\"info-label\">Readiness Score</div>\n        <div class=\"score-value\">{{ $json['Readiness Score'] }}/100</div>\n      </div>\n\n      <div class=\"info-card\">\n        <div class=\"info-label\">Date Created</div>\n        <div class=\"info-value\">{{ $json['Date Created'] }}</div>\n      </div>\n\n      <div class=\"info-card\" style=\"grid-column: 1 / -1;\">\n        <div class=\"info-label\">Student Folder</div>\n        <div class=\"info-value\">\n          <a href=\"{{ $json['Drive Folder Link'] }}\" class=\"folder-link\">📁 Open Student Folder</a>\n        </div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2 class=\"section-title\">📌 Your Next Action</h2>\n    <div class=\"action-box\">\n      This student has just been assigned to you. Please reach out via WhatsApp within the next 2 hours to introduce yourself and schedule an initial counselling session.<br><br>Once the session is complete, update the student's stage using the Stage Update Form.\n    </div>\n  </div>\n\n  <div class=\"footer\">\n    This notification was automatically generated by your Study Abroad Pipeline.<br>Please do not reply to this