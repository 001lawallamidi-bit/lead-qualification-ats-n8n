    {
      "parameters": {
        "jsCode": "const lead = $items('Merge', 0, 0)[0].json; \nconst allRows = $input.all().map(i => i.json);\n\n// 1. Filter active counsellors and grab their Last_Assigned timestamp\nconst counsellors = allRows\n  .filter(r => String(r.Active ?? '').trim().toLowerCase() === 'true')\n  .map(c => ({\n    ...c,\n    _lastAssigned: c.Last_Assigned ? String(c.Last_Assigned).trim() : ''\n  }));\n\nif (counsellors.length === 0) {\n  throw new Error('No active counsellors found.');\n}\n\n// 2. Sort: Blanks first -> Oldest timestamp -> Counsellor_ID tie-breaker\ncounsellors.sort((a, b) => {\n  if (!a._lastAssigned && b._lastAssigned) return -1;\n  if (!b._lastAssigned && a._lastAssigned) return 1;\n  if (a._lastAssigned !== b._lastAssigned) return a._lastAssigned.localeCompare(b._lastAssigned);\n  return String(a.Counsellor_ID ?? '').localeCompare(String(b.Counsellor_ID ?? ''));\n});\n\n// 3. Pick the first one in the sorted list\nconst assigned = counsellors[0];\n\n// 4. Output\nreturn [\n  {\n    json: {\n      ...lead,\n      assigned_counsellor_id: assigned.Counsellor_ID ?? '',\n      assigned_counsellor_name: assigned.Name ?? '',\n      assigned_counsellor_email: assigned.Email ?? '',\n      assigned_counsellor_phone: assigned.Phone ?? assigned['Whatsapp Number'] ?? '',\n      assignment_pool_debug: counsellors.map(c => \n        `${c.Counsellor_ID === assigned.Counsellor_ID ? '>>> ' : ''}${c.Counsellor_ID} - ${c.Name} (${c._lastAssigned || 'blank'})`\n      ).join(' | ')\n    }\n  }\n];"
      },
